// Astronomy frame stacking: accumulate N noisy exposures, then scale.
// Signal reinforces, noise cancels by sqrt(N).
//
// Dual-accumulator f32x8 loops with software prefetch for ILP.
// Three kernels: accumulate (called N times), scale (called once),
// frame_stats (single-pass min/max/sum of final result).

// In-place accumulation: acc[i] += frame[i]
// Dual f32x8 accumulators with prefetch for instruction-level parallelism.
export func accumulate_f32x8(acc: *mut f32, frame: *restrict f32, len: i32) {
    let mut i: i32 = 0

    // Main loop: 16 floats per iteration (2x f32x8)
    while i + 16 <= len {
        prefetch(acc, i + 64)
        prefetch(frame, i + 64)
        let va0: f32x8 = load(acc, i)
        let vf0: f32x8 = load(frame, i)
        let va1: f32x8 = load(acc, i + 8)
        let vf1: f32x8 = load(frame, i + 8)
        store(acc, i, va0 .+ vf0)
        store(acc, i + 8, va1 .+ vf1)
        i = i + 16
    }

    // Residual full vector
    while i + 8 <= len {
        let va: f32x8 = load(acc, i)
        let vf: f32x8 = load(frame, i)
        store(acc, i, va .+ vf)
        i = i + 8
    }

    // Scalar tail
    while i < len {
        acc[i] = acc[i] + frame[i]
        i = i + 1
    }
}

// Batched accumulation: acc[i] += f0[i] + f1[i] + f2[i] + f3[i]
// One pass over acc per 4 frames instead of 4 passes.
// Reduces acc memory traffic by ~2x vs single-frame loop.
export func accumulate_batch4_f32x8(
    acc: *mut f32,
    f0: *restrict f32,
    f1: *restrict f32,
    f2: *restrict f32,
    f3: *restrict f32,
    len: i32
) {
    let mut i: i32 = 0

    while i + 16 <= len {
        prefetch(acc, i + 64)
        prefetch(f0, i + 64)
        prefetch(f1, i + 64)
        prefetch(f2, i + 64)
        prefetch(f3, i + 64)

        let a0: f32x8 = load(acc, i)
        let a1: f32x8 = load(acc, i + 8)
        let v00: f32x8 = load(f0, i)
        let v01: f32x8 = load(f0, i + 8)
        let v10: f32x8 = load(f1, i)
        let v11: f32x8 = load(f1, i + 8)
        let v20: f32x8 = load(f2, i)
        let v21: f32x8 = load(f2, i + 8)
        let v30: f32x8 = load(f3, i)
        let v31: f32x8 = load(f3, i + 8)

        store(acc, i, a0 .+ v00 .+ v10 .+ v20 .+ v30)
        store(acc, i + 8, a1 .+ v01 .+ v11 .+ v21 .+ v31)
        i = i + 16
    }

    while i + 8 <= len {
        let a: f32x8 = load(acc, i)
        let v0: f32x8 = load(f0, i)
        let v1: f32x8 = load(f1, i)
        let v2: f32x8 = load(f2, i)
        let v3: f32x8 = load(f3, i)
        store(acc, i, a .+ v0 .+ v1 .+ v2 .+ v3)
        i = i + 8
    }

    while i < len {
        acc[i] = acc[i] + f0[i] + f1[i] + f2[i] + f3[i]
        i = i + 1
    }
}

// Batched accumulation: 8 frames at once.
// One pass over acc per 8 frames instead of 8 passes.
// Reduces acc memory traffic by ~2.4x vs single-frame loop.
export func accumulate_batch8_f32x8(
    acc: *mut f32,
    f0: *restrict f32,
    f1: *restrict f32,
    f2: *restrict f32,
    f3: *restrict f32,
    f4: *restrict f32,
    f5: *restrict f32,
    f6: *restrict f32,
    f7: *restrict f32,
    len: i32
) {
    let mut i: i32 = 0

    while i + 16 <= len {
        prefetch(acc, i + 64)
        prefetch(f0, i + 64)
        prefetch(f1, i + 64)
        prefetch(f2, i + 64)
        prefetch(f3, i + 64)
        prefetch(f4, i + 64)
        prefetch(f5, i + 64)
        prefetch(f6, i + 64)
        prefetch(f7, i + 64)

        let a0: f32x8 = load(acc, i)
        let a1: f32x8 = load(acc, i + 8)
        let v00: f32x8 = load(f0, i)
        let v01: f32x8 = load(f0, i + 8)
        let v10: f32x8 = load(f1, i)
        let v11: f32x8 = load(f1, i + 8)
        let v20: f32x8 = load(f2, i)
        let v21: f32x8 = load(f2, i + 8)
        let v30: f32x8 = load(f3, i)
        let v31: f32x8 = load(f3, i + 8)
        let v40: f32x8 = load(f4, i)
        let v41: f32x8 = load(f4, i + 8)
        let v50: f32x8 = load(f5, i)
        let v51: f32x8 = load(f5, i + 8)
        let v60: f32x8 = load(f6, i)
        let v61: f32x8 = load(f6, i + 8)
        let v70: f32x8 = load(f7, i)
        let v71: f32x8 = load(f7, i + 8)

        store(acc, i,     a0 .+ v00 .+ v10 .+ v20 .+ v30 .+ v40 .+ v50 .+ v60 .+ v70)
        store(acc, i + 8, a1 .+ v01 .+ v11 .+ v21 .+ v31 .+ v41 .+ v51 .+ v61 .+ v71)
        i = i + 16
    }

    while i + 8 <= len {
        let a: f32x8 = load(acc, i)
        let v0: f32x8 = load(f0, i)
        let v1: f32x8 = load(f1, i)
        let v2: f32x8 = load(f2, i)
        let v3: f32x8 = load(f3, i)
        let v4: f32x8 = load(f4, i)
        let v5: f32x8 = load(f5, i)
        let v6: f32x8 = load(f6, i)
        let v7: f32x8 = load(f7, i)
        store(acc, i, a .+ v0 .+ v1 .+ v2 .+ v3 .+ v4 .+ v5 .+ v6 .+ v7)
        i = i + 8
    }

    while i < len {
        acc[i] = acc[i] + f0[i] + f1[i] + f2[i] + f3[i] + f4[i] + f5[i] + f6[i] + f7[i]
        i = i + 1
    }
}

// Non-temporal variant of batch8 for comparison benchmarking.
// Uses stream_store to bypass cache on write-back.
// Better than regular store when acc exceeds L3 cache.
export func accumulate_batch8_f32x8_nt(
    acc: *mut f32,
    f0: *restrict f32,
    f1: *restrict f32,
    f2: *restrict f32,
    f3: *restrict f32,
    f4: *restrict f32,
    f5: *restrict f32,
    f6: *restrict f32,
    f7: *restrict f32,
    len: i32
) {
    let mut i: i32 = 0

    while i + 16 <= len {
        prefetch(acc, i + 64)
        prefetch(f0, i + 64)
        prefetch(f1, i + 64)
        prefetch(f2, i + 64)
        prefetch(f3, i + 64)
        prefetch(f4, i + 64)
        prefetch(f5, i + 64)
        prefetch(f6, i + 64)
        prefetch(f7, i + 64)

        let a0: f32x8 = load(acc, i)
        let a1: f32x8 = load(acc, i + 8)
        let v00: f32x8 = load(f0, i)
        let v01: f32x8 = load(f0, i + 8)
        let v10: f32x8 = load(f1, i)
        let v11: f32x8 = load(f1, i + 8)
        let v20: f32x8 = load(f2, i)
        let v21: f32x8 = load(f2, i + 8)
        let v30: f32x8 = load(f3, i)
        let v31: f32x8 = load(f3, i + 8)
        let v40: f32x8 = load(f4, i)
        let v41: f32x8 = load(f4, i + 8)
        let v50: f32x8 = load(f5, i)
        let v51: f32x8 = load(f5, i + 8)
        let v60: f32x8 = load(f6, i)
        let v61: f32x8 = load(f6, i + 8)
        let v70: f32x8 = load(f7, i)
        let v71: f32x8 = load(f7, i + 8)

        stream_store(acc, i,     a0 .+ v00 .+ v10 .+ v20 .+ v30 .+ v40 .+ v50 .+ v60 .+ v70)
        stream_store(acc, i + 8, a1 .+ v01 .+ v11 .+ v21 .+ v31 .+ v41 .+ v51 .+ v61 .+ v71)
        i = i + 16
    }

    while i + 8 <= len {
        let a: f32x8 = load(acc, i)
        let v0: f32x8 = load(f0, i)
        let v1: f32x8 = load(f1, i)
        let v2: f32x8 = load(f2, i)
        let v3: f32x8 = load(f3, i)
        let v4: f32x8 = load(f4, i)
        let v5: f32x8 = load(f5, i)
        let v6: f32x8 = load(f6, i)
        let v7: f32x8 = load(f7, i)
        stream_store(acc, i, a .+ v0 .+ v1 .+ v2 .+ v3 .+ v4 .+ v5 .+ v6 .+ v7)
        i = i + 8
    }

    while i < len {
        acc[i] = acc[i] + f0[i] + f1[i] + f2[i] + f3[i] + f4[i] + f5[i] + f6[i] + f7[i]
        i = i + 1
    }
}

// Scale: out[i] = data[i] * factor
// Called with factor = 1.0 / N to compute mean.
// Dual f32x8 accumulators with prefetch.
export func scale_f32x8(data: *restrict f32, out: *mut f32, len: i32, factor: f32) {
    let vfactor: f32x8 = splat(factor)
    let mut i: i32 = 0

    // Main loop: 16 floats per iteration (2x f32x8)
    while i + 16 <= len {
        prefetch(data, i + 64)
        let v0: f32x8 = load(data, i)
        let v1: f32x8 = load(data, i + 8)
        store(out, i, v0 .* vfactor)
        store(out, i + 8, v1 .* vfactor)
        i = i + 16
    }

    // Residual full vector
    while i + 8 <= len {
        let v: f32x8 = load(data, i)
        store(out, i, v .* vfactor)
        i = i + 8
    }

    // Scalar tail
    while i < len {
        out[i] = data[i] * factor
        i = i + 1
    }
}

// Single-pass min/max/sum of stacked result.
// Dual-accumulator reductions for ILP.
// Writes results to out_min[0], out_max[0], out_sum[0].
export func frame_stats(
    data: *restrict f32,
    len: i32,
    out_min: *mut f32,
    out_max: *mut f32,
    out_sum: *mut f32
) {
    let init_val: f32 = data[0]
    let mut sum_acc0: f32x8 = splat(0.0)
    let mut sum_acc1: f32x8 = splat(0.0)
    let mut min_acc0: f32x8 = splat(init_val)
    let mut min_acc1: f32x8 = splat(init_val)
    let mut max_acc0: f32x8 = splat(init_val)
    let mut max_acc1: f32x8 = splat(init_val)

    let mut i: i32 = 0

    // Main loop: 16 floats per iteration (2x f32x8)
    while i + 16 <= len {
        prefetch(data, i + 64)
        let v0: f32x8 = load(data, i)
        let v1: f32x8 = load(data, i + 8)

        sum_acc0 = sum_acc0 .+ v0
        sum_acc1 = sum_acc1 .+ v1

        min_acc0 = select(v0 .< min_acc0, v0, min_acc0)
        min_acc1 = select(v1 .< min_acc1, v1, min_acc1)

        max_acc0 = select(v0 .> max_acc0, v0, max_acc0)
        max_acc1 = select(v1 .> max_acc1, v1, max_acc1)

        i = i + 16
    }

    // Residual full vector
    while i + 8 <= len {
        let v: f32x8 = load(data, i)
        sum_acc0 = sum_acc0 .+ v
        min_acc0 = select(v .< min_acc0, v, min_acc0)
        max_acc0 = select(v .> max_acc0, v, max_acc0)
        i = i + 8
    }

    // Merge dual accumulators
    let sum_merged: f32x8 = sum_acc0 .+ sum_acc1
    let min_merged: f32x8 = select(min_acc0 .< min_acc1, min_acc0, min_acc1)
    let max_merged: f32x8 = select(max_acc0 .> max_acc1, max_acc0, max_acc1)

    // Horizontal reduction
    let mut total_sum: f32 = reduce_add(sum_merged)
    let mut total_min: f32 = reduce_min(min_merged)
    let mut total_max: f32 = reduce_max(max_merged)

    // Scalar tail
    while i < len {
        let v: f32 = data[i]
        total_sum = total_sum + v
        total_min = min(v, total_min)
        total_max = max(v, total_max)
        i = i + 1
    }

    out_min[0] = total_min
    out_max[0] = total_max
    out_sum[0] = total_sum
}
