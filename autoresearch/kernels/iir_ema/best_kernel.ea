// First-order IIR / Exponential Moving Average
// y[i] = alpha * x[i] + (1 - alpha) * y[i-1]
export func ema_filter(input: *restrict f32, output: *mut f32, len: i32, alpha: f32) {
    if len <= 0 { return }
    let beta: f32 = 1.0 - alpha
    output[0] = alpha * input[0]
    let mut i: i32 = 1
    while i < len {
        output[i] = alpha * input[i] + beta * output[i - 1]
        i = i + 1
    }
}
